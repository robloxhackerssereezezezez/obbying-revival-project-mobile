[sub_resource type="GDScript" id="GDScript_2nypq"]
resource_name = "Location"
script/source = "extends Button

func _on_pressed() -> void:
	OS.shell_show_in_file_manager(ProjectSettings.globalize_path(\"user://levels\"),true)
"

[sub_resource type="GDScript" id="GDScript_7la6k"]
resource_name = "Reload"
script/source = "extends Button

func _on_pressed() -> void:
	owner.load_all_levels()
"

[sub_resource type="Shader" id="Shader_8a8k8"]
code = "shader_type canvas_item;

uniform float star_density : hint_range(0.01, 1.0) = 1;
uniform float elapsed_time;
uniform vec2 direction = vec2(-1.0, 0.0); // Allow diagonal movement

float rand(vec2 uv) {
    return fract(sin(dot(uv, vec2(12.9898, 78.233))) * 43758.5453);
}

void fragment() {
    // 1. Use TIME multiplied by speed for movement.
    // Wrap it using fract() if you want to keep TIME values small,
    // though for simple UV scrolling, TIME is usually fine.
    vec2 movement = direction * elapsed_time * .0125;
    vec2 uv = UV + movement;
    
    // 2. Scale the grid (increase 50.0 for smaller/more stars)
    vec2 grid_uv = fract(uv * 360.0); 
    vec2 grid_id = floor(uv * 360.0);
    
    // 3. Randomness for placement and \"twinkle\"
    float r = rand(grid_id);
    float star = 0.0;
    
    if (r > (1.0 - star_density * 0.1)) {
        // Create a circular dot
        float dist = distance(grid_uv, vec2(0.5));
        
        // 4. Frame-independent twinkling:
        // We use sin(TIME) but offset it by our random value 'r' 
        // so all stars don't blink at the exact same time.
        float twinkle = sin(elapsed_time * 6.0 + r * 100.0) * 0.5 + 0.5;
        
        star = smoothstep(0.1, 0.02, dist) * twinkle;
    }
    
    // Output white stars on a transparent/black background
    COLOR = vec4(vec3(star), 1.0);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_7la6k"]
shader = SubResource("Shader_8a8k8")
shader_parameter/star_density = 0.5
shader_parameter/elapsed_time = 16.937500000000163
shader_parameter/direction = Vector2(-1, 0)

[sub_resource type="GDScript" id="GDScript_ucygd"]
script/source = "extends ColorRect
var elapsed_time:float

func _process(delta: float) -> void:
	elapsed_time += delta
	var mat = material as ShaderMaterial
	mat.set_shader_parameter(\"elapsed_time\",elapsed_time)
"

